message(STATUS "Starting Musil uninstall...")

set(PREFIX "@CMAKE_INSTALL_PREFIX@")
set(IS_APPLE "@APPLE@")

# ------------------------------------------------------------------------------
# Remove ~/.musil
# ------------------------------------------------------------------------------

if(DEFINED ENV{HOME})
    set(MUSIL_HOME "$ENV{HOME}/.musil")
    if(EXISTS "${MUSIL_HOME}")
        message(STATUS "Removing directory: ${MUSIL_HOME}")
        file(REMOVE_RECURSE "${MUSIL_HOME}")
    else()
        message(STATUS "~/.musil directory not present")
    endif()

    # --------------------------------------------------------------------------
    # Remove ~/.musilrc
    # --------------------------------------------------------------------------

    set(MUSIL_RC "$ENV{HOME}/.musilrc")
    if(EXISTS "${MUSIL_RC}")
        message(STATUS "Removing file: ${MUSIL_RC}")
        file(REMOVE "${MUSIL_RC}")
    else()
        message(STATUS "~/.musilrc not present")
    endif()
endif()

# ------------------------------------------------------------------------------
# Remove CLI binary from install prefix
# ------------------------------------------------------------------------------

set(MUSIL_BIN "${PREFIX}/bin/musil")
if(EXISTS "${MUSIL_BIN}")
    message(STATUS "Removing CLI binary: ${MUSIL_BIN}")
    file(REMOVE "${MUSIL_BIN}")
else()
    message(STATUS "CLI binary not found: ${MUSIL_BIN}")
endif()

# ------------------------------------------------------------------------------
# Remove app bundle from /Applications on macOS
# ------------------------------------------------------------------------------

if(IS_APPLE)
    set(MUSIL_APP "/Applications/Musil IDE.app")
    if(EXISTS "${MUSIL_APP}")
        message(STATUS "Removing application bundle: ${MUSIL_APP}")
        file(REMOVE_RECURSE "${MUSIL_APP}")
    else()
        message(STATUS "Musil IDE.app not found in /Applications")
    endif()
endif()

message(STATUS "Musil uninstall completed.")